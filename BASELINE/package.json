{
  "name": "zizou",
  "version": "0.1.0",
  "description": "An open-source AI coding agent for your terminal — bring your own API key.",
  "type": "module",
  "bin": {
    "zizou": "./src/cli.tsx"
  },
  "scripts": {
    "dev": "bun run src/cli.tsx",
    "typecheck": "tsc -p tsconfig.json",
    "build": "bun build src/cli.tsx --compile --outfile zizou-bin"
  },
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.0",
    "@ai-sdk/openai": "^4.0.0",
    "ai": "^7.0.2",
    "conf": "^15.1.0",
    "ink": "^7.1.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.7",
    "typescript": "^5.9.0"
  }
}
