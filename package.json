{
  "name": "zizou-ai",
  "version": "0.1.1",
  "type": "module",
  "description": "An open-source AI coding agent CLI tool",
  "bin": {
    "zizou": "./dist/cli.js"
  },
  "scripts": {
    "dev": "bun run src/cli.tsx",
    "dev-harness": "bun run src/dev-harness.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "bun run build.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.0",
    "@ai-sdk/google": "^4.0.0",
    "@ai-sdk/groq": "^4.0.0",
    "@ai-sdk/openai": "^4.0.0",
    "ai": "^7.0.0",
    "conf": "^12.0.0",
    "esbuild": "^0.28.1",
    "ink": "^7.1.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.7",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.17",
    "typescript": "^6.0.3"
  }
}
